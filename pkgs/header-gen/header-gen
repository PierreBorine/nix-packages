# fmt: on


SPLIT_RE = re.compile(r"\x1B\[\d+(?:;\d+){0,4}m|.")


def main() -> None:
    offset = 1
    clean = False
    if sys.argv[1] in ["-c", "--clean"]:
        offset += 1
        clean = True

    text = " ".join(sys.argv[offset:])
    # Process escape sequences (eg: "\x1B")
    text = bytes(text, "utf-8").decode("unicode_escape")
    # Split ANSI codes and characters, filter newlines out
    chars = re.findall(SPLIT_RE, text)

    top = ""
    bot = ""
    length = 0
    for char in chars:
        # Normal character
        if len(char) == 1:
            char = char.upper()
            if length > 0:
                top += " "
                bot += " "
            top += CHARSET.get(f"{char}_TOP", "   ")
            bot += CHARSET.get(f"{char}_BOT", "   ")
            length += 1
        # ANSI code
        else:
            top += char
            bot += char
    if clean:
        top = top.replace("‚ĖĎ", " ")
        bot = bot.replace("‚ĖĎ", " ")
    print(top)
    print(bot)


if __name__ == "__main__":
    main()
